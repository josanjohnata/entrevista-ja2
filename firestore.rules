rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       FUNÇÕES AUXILIARES
    ========================== */
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    /* =========================
       USERS
       - Cada usuário só acessa o próprio doc
       - IMPORTANTE: Separar create explicitamente para garantir criação inicial
       - Proteção: validação de que userId no documento corresponde ao uid do usuário
    ========================== */
    match /users/{userId} {
      // Permitir criação: usuário autenticado pode criar seu próprio documento
      // IMPORTANTE: userId no path DEVE corresponder ao uid do usuário autenticado
      allow create: if isOwner(userId);
      
      // Permitir leitura: usuário autenticado pode ler apenas seu próprio documento
      allow read: if isOwner(userId);
      
      // Permitir atualização: usuário autenticado pode atualizar apenas seu próprio documento
      // PROTEÇÃO CRÍTICA: usuário só pode mudar subscriptionStatus para "canceled" ou manter o mesmo valor
      // PROTEÇÃO: não pode mudar role, planId, balance, referralCode, referredBy ou outros campos críticos
      // PERMITIDO: usuário pode atualizar pixKey (chave PIX para pagamentos)
      // NOTA: updatedAt pode ser atualizado, mas será sobrescrito pelo servidor se necessário
      allow update: if isOwner(userId) && 
                       // userId não pode ser alterado
                       (!request.resource.data.keys().hasAny(['userId']) || 
                        request.resource.data.userId == userId) &&
                       // role não pode ser alterado pelo usuário (se existir no documento)
                       (!request.resource.data.keys().hasAny(['role']) ||
                        !resource.data.keys().hasAny(['role']) ||
                        request.resource.data.role == resource.data.role) &&
                       // planId não pode ser alterado pelo usuário (se existir no documento)
                       (!request.resource.data.keys().hasAny(['planId']) ||
                        !resource.data.keys().hasAny(['planId']) ||
                        request.resource.data.planId == resource.data.planId) &&
                       // balance não pode ser alterado pelo usuário (apenas Cloud Functions)
                       (!request.resource.data.keys().hasAny(['balance']) ||
                        !resource.data.keys().hasAny(['balance']) ||
                        request.resource.data.balance == resource.data.balance) &&
                       // subscriptionStatus: permite se não está sendo modificado, 
                       // ou se está sendo mudado para 'canceled',
                       // ou se o documento não tinha subscriptionStatus antes (primeira criação via merge)
                       (!request.resource.data.keys().hasAny(['subscriptionStatus']) ||
                        request.resource.data.subscriptionStatus == 'canceled' ||
                        !resource.data.keys().hasAny(['subscriptionStatus'])) &&
                       // referralCode não pode ser alterado pelo usuário (apenas Cloud Functions)
                       (!request.resource.data.keys().hasAny(['referralCode']) ||
                        !resource.data.keys().hasAny(['referralCode']) ||
                        request.resource.data.referralCode == resource.data.referralCode) &&
                       // referredBy não pode ser alterado pelo usuário (apenas Cloud Functions)
                       (!request.resource.data.keys().hasAny(['referredBy']) ||
                        !resource.data.keys().hasAny(['referredBy']) ||
                        request.resource.data.referredBy == resource.data.referredBy);
      
      // Permitir exclusão: usuário autenticado pode excluir apenas seu próprio documento
      allow delete: if isOwner(userId);
    }

    /* =========================
       PROFILES
       - Cada usuário só acessa o próprio perfil
    ========================== */
    match /profiles/{userId} {
      // Permitir criação: usuário autenticado pode criar seu próprio perfil
      allow create: if isOwner(userId);
      // Permitir leitura: usuário autenticado pode ler apenas seu próprio perfil
      allow read: if isOwner(userId);
      // Permitir atualização: usuário autenticado pode atualizar apenas seu próprio perfil
      allow update: if isOwner(userId);
      // Permitir exclusão: usuário autenticado pode excluir apenas seu próprio perfil
      allow delete: if isOwner(userId);
    }

    /* =========================
       STATS
       - Público para leitura
       - Escrita APENAS no documento 'users' (contador de usuários)
       - Proteção: usuários não podem criar/modificar outros documentos de stats
       - Proteção: não permite exclusão de stats
    ========================== */
    match /stats/{docId} {
      allow read: if true;
      
      // Permitir escrita APENAS no documento 'users' (contador de usuários)
      // Isso previne que atacantes criem/modifiquem outros documentos de stats
      allow write: if isAuthenticated() && docId == 'users';
      
      // Bloquear exclusão de stats (proteção adicional)
      allow delete: if false;
    }

    /* =========================
       REFERRALS
       - Usuário pode ler suas próprias indicações (como referrer ou referred)
       - Apenas Cloud Functions podem criar/atualizar indicações
    ========================== */
    match /referrals/{referralId} {
      // Permitir leitura: usuário pode ler indicações onde ele é o referrer ou o indicado
      allow read: if isAuthenticated() && (
        resource.data.referrerUid == request.auth.uid ||
        resource.data.referredUid == request.auth.uid
      );
      
      // Apenas Cloud Functions podem criar/atualizar (via Admin SDK)
      allow write: if false;
    }

    /* =========================
       PAYMENTS
       - Usuário pode ler seus próprios pagamentos
       - Apenas Cloud Functions podem criar/atualizar pagamentos
    ========================== */
    match /payments/{paymentId} {
      // Permitir leitura: usuário pode ler apenas seus próprios pagamentos
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Apenas Cloud Functions podem criar/atualizar (via Admin SDK)
      allow write: if false;
    }

    /* =========================
       PAYOUTS
       - Usuário pode ler seus próprios saques
       - Apenas Cloud Functions podem criar/atualizar saques
    ========================== */
    match /payouts/{payoutId} {
      // Permitir leitura: usuário pode ler apenas seus próprios saques
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Apenas Cloud Functions podem criar/atualizar (via Admin SDK)
      allow write: if false;
    }

    /* =========================
       EXEMPLO DE COLEÇÃO PRIVADA
    ========================== */
    match /privateData/{docId} {
      allow read, write: if isAdmin();
    }

    /* =========================
       BLOQUEIO GLOBAL (OBRIGATÓRIO)
       - NADA fora do que foi definido acima
    ========================== */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
